  document.getElementById('cfg-total-nights').textContent=tot-1;
  document.getElementById('cfg-total-days').textContent=tot;
  saveData(); renderAll();
}

// ===================== PERSISTENCE =====================
const LS_KEY='europa2027_v2';
function saveData() {
  try{localStorage.setItem(LS_KEY,JSON.stringify({reales:S.reales,scenario:S.scenario,budget:S.budget,tc:S.tc,emergPct:S.emergPct,days:{...S.days},hotel:{...S.hotel},food:{...S.food}}))}catch(e){}
}
function loadData() {
  try{
    const raw=localStorage.getItem(LS_KEY);
    if(!raw) return;
    const d=JSON.parse(raw);
    if(d.reales) S.reales=d.reales;
    if(d.scenario) S.scenario=d.scenario;
    if(d.budget) { S.budget=d.budget; S.scenarios.base=d.budget; }
    if(d.tc) S.tc=d.tc;
    if(d.emergPct) S.emergPct=d.emergPct;
    if(d.days) Object.assign(S.days,d.days);
    if(d.hotel) Object.assign(S.hotel,d.hotel);
    if(d.food) Object.assign(S.food,d.food);
    // Sync config inputs
    const setVal=(id,v)=>{ const el=document.getElementById(id); if(el) el.value=v; };
    setVal('cfg-budget',S.budget); setVal('cfg-tc',S.tc); setVal('cfg-emerg',S.emergPct);
    setVal('cfg-d-paris',S.days.paris); setVal('cfg-d-suiza',S.days.suiza);
    setVal('cfg-d-roma',S.days.roma); setVal('cfg-d-florencia',S.days.florencia);
    setVal('cfg-d-venecia',S.days.venecia); setVal('cfg-d-amsterdam',S.days.amsterdam);
    setVal('cfg-d-praga',S.days.praga);
  }catch(e){}
}

