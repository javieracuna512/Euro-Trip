    const diffCls = diff===null?'neu':diff>=0?'pos':'neg';
    const diffStr = diff===null?'—':(diff>=0?'+':'')+' $'+Math.abs(Math.round(diff));
    const pctStr = diffPct===null?'—':(diffPct>=0?'+':'')+diffPct.toFixed(1)+'%';
    const sem = dayRealTotal!==null ? getSemaforo((cumReal/cumPlan)*100) : {type:'blue',label:'PENDIENTE'};
