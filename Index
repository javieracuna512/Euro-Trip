function updateKPIs() {
  const t=getTotals();
  const budget=S.scenarios[S.scenario];
  const emergAmt=Math.round(budget*S.emergPct/100);
  const {totalReal,daysWithData}=getRealTotals();
  const disponible=budget-totalReal;
  const margin=budget-t.grandTotal;
  const burnPlan=Math.round(t.grandTotal/15);
  const burnReal=daysWithData>0?Math.round(totalReal/daysWithData):null;
  const desv=t.grandTotal-budget;
  const daysRest=15-daysWithData;
  const cpd=daysWithData>0?Math.round(totalReal/daysWithData):null;
  const projFinal=daysWithData>=3?Math.round((totalReal/daysWithData)*15):t.grandTotal;
  const dailyRest=daysRest>0?Math.round((disponible)/daysRest):0;
  const semPct=t.grandTotal/budget*100;

  document.getElementById('kpi-presupuesto').textContent='$'+budget.toLocaleString();
  document.getElementById('kpi-proyeccion').textContent='$'+Math.round(t.grandTotal).toLocaleString();
  document.getElementById('kpi-real').textContent='$'+Math.round(totalReal).toLocaleString();
  document.getElementById('kpi-real-sub').textContent=daysWithData+' días registrados';
  document.getElementById('kpi-disponible').textContent='$'+Math.round(disponible).toLocaleString();
  document.getElementById('kpi-disponible').style.color=disponible>0?'var(--green)':'var(--red)';
  document.getElementById('kpi-emergencia').textContent='$'+emergAmt.toLocaleString();
  document.getElementById('kpi-burn-plan').textContent='$'+burnPlan+'/d';
  document.getElementById('kpi-burn-real').textContent=burnReal?'$'+burnReal+'/d':'Sin data';
  document.getElementById('kpi-burn-real-sub').textContent=daysWithData>0?`${daysWithData} días con datos`:'Sin datos aún';
  const desvEl=document.getElementById('kpi-desviacion');
  desvEl.textContent=(desv>=0?'+':'')+' $'+Math.round(Math.abs(desv));
  desvEl.style.color=desv<=0?'var(--green)':'var(--red)';
  document.getElementById('kpi-dias-rest').textContent=daysRest;
  document.getElementById('kpi-cpd').textContent=cpd?'$'+cpd+'/d':'—';
  document.getElementById('kpi-proj-final2').textContent='$'+projFinal.toLocaleString();
  document.getElementById('kpi-pf2-sub').textContent=daysWithData>=3?`Basado en ${daysWithData} días`:'Sin suficiente data';
  document.getElementById('kpi-pf2-sub').style.color=projFinal>budget?'var(--red)':'var(--green)';
  const dailyRestEl=document.getElementById('kpi-daily-rest');
  dailyRestEl.textContent='$'+Math.max(0,dailyRest)+'/d';
  dailyRestEl.style.color=dailyRest>=burnPlan?'var(--green)':dailyRest>0?'var(--amber)':'var(--red)';

  document.getElementById('h-budget').textContent='$'+budget.toLocaleString();
  document.getElementById('h-proj').textContent='$'+Math.round(t.grandTotal).toLocaleString();
  document.getElementById('h-real').textContent='$'+Math.round(totalReal).toLocaleString();
  const hmEl=document.getElementById('h-margin');
  hmEl.textContent=(margin>=0?'+':'')+' $'+Math.round(Math.abs(margin));
  hmEl.style.color=margin>=0?'var(--green)':'var(--red)';
  document.getElementById('strip-tc').textContent=S.tc;
  document.getElementById('strip-date').textContent=new Date().toLocaleDateString('es-PE',{day:'2-digit',month:'short',year:'numeric'});

  renderSemaforo(semPct, document.getElementById('kpi-semaforo-big'), true);
  renderSemaforo(semPct, document.getElementById('h-semaforo'));

  // Velocidad panel
  const vPanel=document.getElementById('velocidad-panel');
  if(vPanel && daysWithData>=2){
    const daysArr=buildDays();
    let consec=0; let prevOver=false;
    daysArr.forEach((d,i)=>{
      const r=parseFloat(S.reales[i]);
      if(!isNaN(r)&&r>d.budget) { if(prevOver) consec++; prevOver=true; } else prevOver=false;
    });
    const trend=burnReal>burnPlan?'ACELERADO':'NORMAL';
    const trendColor=burnReal>burnPlan?'var(--red)':'var(--green)';
    vPanel.innerHTML=`
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
        <div style="background:var(--bg);border-radius:var(--r);padding:12px;text-align:center">
          <div class="kpi-label">Tendencia</div>
          <div class="kpi-value" style="font-size:16px;color:${trendColor}">${trend}</div>
        </div>
        <div style="background:var(--bg);border-radius:var(--r);padding:12px;text-align:center">
          <div class="kpi-label">Días consecutivos sobre presupuesto</div>
          <div class="kpi-value" style="font-size:16px;color:${consec>2?'var(--red)':'var(--green)'}">${consec}</div>
        </div>
        <div style="background:var(--bg);border-radius:var(--r);padding:12px;text-align:center">
          <div class="kpi-label">Costo/día real</div>
          <div class="kpi-value" style="font-size:16px;color:var(--cyan)">$${burnReal??'—'}</div>
        </div>
        <div style="background:var(--bg);border-radius:var(--r);padding:12px;text-align:center">
          <div class="kpi-label">Costo/día plan</div>
          <div class="kpi-value" style="font-size:16px;color:var(--blue)">$${burnPlan}</div>
        </div>
      </div>`;
  }

  // Alerts
  const alertsEl=document.getElementById('dashboard-alerts');
  if(alertsEl){
    let alerts='';
    if(margin<0) alerts+=`<div class="alert-strip alert-red"><span>⚠</span><div><strong>ALERTA:</strong> El presupuesto proyectado ($${Math.round(t.grandTotal).toLocaleString()}) excede el asignado ($${budget.toLocaleString()}) en $${Math.abs(Math.round(margin)).toLocaleString()}. Considera reducir noches en Suiza o saltar Praga.</div></div>`;
    if(margin>=0&&margin<300) alerts+=`<div class="alert-strip alert-amber"><span>△</span><div><strong>MARGEN AJUSTADO:</strong> Quedan $${Math.round(margin).toLocaleString()} de margen. Fondo emergencia recomendado: $${emergAmt.toLocaleString()}. Evita gastos no planificados.</div></div>`;
    if(margin>=300) alerts+=`<div class="alert-strip alert-green"><span>✓</span><div><strong>PRESUPUESTO EN RANGO:</strong> Margen de $${Math.round(margin).toLocaleString()} disponible sobre el total proyectado. Fondo emergencia reservado: $${emergAmt.toLocaleString()}.</div></div>`;
    alerts+=`<div class="alert-strip alert-blue"><span>✈</span><div><strong>VUELO LIM-MAD:</strong> S/3,220 (~$860 USD, Air Canada) es precio competitivo. Con 8 meses de anticipación: COMPRA AHORA. Históricamente sube $150-300 en los 3 meses previos.</div></div>`;
    alertsEl.innerHTML=alerts;
  }
}

// ===================== MAIN RENDER =====================
function renderAll() {
