// ===================== DAY SUBCATEGORY DATA =====================
// Per-day breakdown: [vuelo/tren, hotel, comida, transpLocal, actividades]
const DAY_CATS = ['✈ Vuelo/Tren','🏨 Hotel','🍽 Comida','🚇 Transp. Local','🎟 Actividades'];
const DAY_CAT_KEYS = ['vuelo','hotel','comida','transp','activ'];

function getDaySubBudgets(dayIdx) {
  // Returns {vuelo, hotel, comida, transp, activ} in USD for that day
  const m = SCEN_MULT[S.scenario];
  // Lookup city for this day
  const cityMap = [
    'madrid','paris','paris','paris',
    'suiza','suiza','suiza',
    'roma','roma','roma',
    'florencia','venecia',
    'amsterdam','amsterdam',
    'praga'
  ];
  const cityId = cityMap[dayIdx] || 'paris';
  const cityObj = CITIES.find(c=>c.id===cityId);
  if(!cityObj) return {vuelo:0,hotel:0,comida:0,transp:0,activ:0};

  const b = getCityBudget(cityObj);
  const nights = b.nights || 1;

  // Vuelo only on travel days (day 0=Madrid free, 1=fly to Paris, 4=TGV, 7=fly to Rome, 10=train, 11=train+arrive Venice, 12=fly AMS, 14=fly PRG)
  const flightDays = {1:86,4:65,7:92,10:38,11:38,12:108,14:81};
  const vueloPlan = flightDays[dayIdx] ? Math.round(flightDays[dayIdx]*m) : 0;

  // Hotel: split per night
  const hotelPlan = Math.round((b.hotel * S.tc) / nights);

  // Food per day
  const foodPlan = Math.round(b.food * S.tc / nights);

  // Local transport (metro, bus, taxi) — fixed per city
  const localTransp = {madrid:10,paris:15,suiza:10,roma:12,florencia:8,venecia:10,amsterdam:14,praga:10};
  const transpPlan = Math.round((localTransp[cityId]||10)*m);

  // Activities per day
  const activPlan = Math.round((b.entries / nights));

  return {vuelo:vueloPlan, hotel:hotelPlan, comida:foodPlan, transp:transpPlan, activ:activPlan};
}

function getSubReal(dayIdx, catKey) {
  const key = `r_${dayIdx}_${catKey}`;
  const v = S.reales[key];
  return (v !== undefined && v !== '') ? parseFloat(v)||0 : null;
}

function getDayTotalReal(dayIdx) {
  let total = 0; let hasAny = false;
  DAY_CAT_KEYS.forEach(k => {
    const v = getSubReal(dayIdx, k);
    if(v !== null) { total += v; hasAny = true; }
  });
  return hasAny ? total : null;
}

function renderDiarioTable() {
  const tbody=document.getElementById('diario-tbody');
