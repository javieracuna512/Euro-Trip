  days.forEach((d,i)=>{
    const subs = getDaySubBudgets(i);
    const dayBudget = subs.vuelo + subs.hotel + subs.comida + subs.transp + subs.activ;
    cumPlan += dayBudget;
    totPlan += dayBudget;

    const dayRealTotal = getDayTotalReal(i);
