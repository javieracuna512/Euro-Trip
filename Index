<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script>
// ===================== STATE =====================
const S = {
  scenario: 'base',
  budget: 4000,
  tc: 1.08,
  emergPct: 10,
  flightMain: 860,
  days: { paris:3, suiza:3, roma:3, florencia:1, venecia:1, amsterdam:2, praga:2 },
  hotel: { paris:130, suiza:140, italia:100, amsterdam:120, praga:85 },
  food: { paris:50, suiza:55, italia:40, amsterdam:45, praga:30 },
  scenarios: { conservador:3500, base:4000, holgado:4500 },
  reales: {},
  charts: {}
};

// ===================== CITIES DEF =====================
const CITIES = [
  { id:'madrid',    flag:'🇪🇸', name:'Madrid',    dkey:null,      nights:1, hotelKey:null,        foodKey:null,         transport:0,   entries:0,    dates:'1 Mar',    acts:'Día libre post-maestría · Preparativos salida' },
  { id:'paris',     flag:'🇫🇷', name:'París',     dkey:'paris',   nights:3, hotelKey:'paris',     foodKey:'paris',      transport:86,  entries:75,   dates:'2–4 Mar',  acts:'Louvre €17 · Torre Eiffel €26 · Montmartre' },
  { id:'suiza',     flag:'🇨🇭', name:'Suiza',     dkey:'suiza',   nights:3, hotelKey:'suiza',     foodKey:'suiza',      transport:65,  entries:85,   dates:'5–7 Mar',  acts:'TGV París-Lucerna · Alpes · Interlaken' },
  { id:'roma',      flag:'🇮🇹', name:'Roma',      dkey:'roma',    nights:3, hotelKey:'italia',    foodKey:'italia',     transport:92,  entries:60,   dates:'8–10 Mar', acts:'Coliseo €16 · Vaticano €20 · Fontana Trevi' },
  { id:'florencia', flag:'🇮🇹', name:'Florencia', dkey:'florencia',nights:1,hotelKey:'italia',   foodKey:'italia',     transport:38,  entries:25,   dates:'11 Mar',   acts:'Uffizi €20 · Duomo · Ponte Vecchio' },
  { id:'venecia',   flag:'🇮🇹', name:'Venecia',   dkey:'venecia', nights:1, hotelKey:'italia',    foodKey:'italia',     transport:38,  entries:20,   dates:'12 Mar',   acts:'Góndola €80 · Plaza San Marcos · Rialto' },
  { id:'amsterdam', flag:'🇳🇱', name:'Ámsterdam', dkey:'amsterdam',nights:2,hotelKey:'amsterdam',foodKey:'amsterdam',  transport:108, entries:55,   dates:'13–14 Mar',acts:'VCE→AMS €100 · Rijksmuseum €22 · Canales' },
  { id:'praga',     flag:'🇨🇿', name:'Praga',     dkey:'praga',   nights:2, hotelKey:'praga',     foodKey:'praga',      transport:81,  entries:40,   dates:'15 Mar',   acts:'AMS→PRG €75 · Castillo · Puente Carlos' },
];

const CATS = ['Hoteles','Vuelos Internos','Comida','Actividades/Entradas','Contingencia'];
const CAT_COLORS = ['#3b82f6','#f59e0b','#22c55e','#a855f7','#06b6d4'];
const INTERNAL_FLIGHTS = { conservador:420, base:508, holgado:650 };
const MISC = { conservador:100, base:200, holgado:350 };
const SCEN_MULT = { conservador:0.88, base:1.0, holgado:1.14 };

// ===================== CALC =====================
function getCityBudget(c) {
  const m = SCEN_MULT[S.scenario];
  const tc = S.tc;
  const nights = c.dkey ? S.days[c.dkey] : (c.id==='madrid'?1:0);
  const hotelRate = c.hotelKey ? S.hotel[c.hotelKey] : 0;
  const foodRate = c.foodKey ? S.food[c.foodKey] : (S.food.paris * 0.8);
  const hotel = nights * hotelRate * m;
  const food = nights * foodRate * m;
  const transport = c.transport * m;
  const entries = c.entries * m;
  const totalEur = hotel + food + transport/tc + entries/tc;
  const totalUsd = hotel*tc + food*tc + transport + entries;
  return { hotel, food, transport, entries, totalEur, totalUsd, nights, hotelRate, foodRate };
}

function getTotals() {
  let hotel=0, food=0, transport=0, entries=0, totalUsd=0, totalEur=0;
  CITIES.forEach(c => {
    const b = getCityBudget(c);
    hotel += b.hotel * S.tc;
    food += b.food * S.tc;
    transport += b.transport;
    entries += b.entries;
    totalUsd += b.totalUsd;
    totalEur += b.totalEur;
  });
  const intFlights = INTERNAL_FLIGHTS[S.scenario];
  const misc = MISC[S.scenario];
  return { hotel, food, transport, entries, totalUsd, totalEur, intFlights, misc, grandTotal: totalUsd + misc };
}

function getRealTotals() {
  let totalReal = 0, daysWithData = 0;
  Object.values(S.reales).forEach(v => {
    if(v !== '' && v !== undefined && !isNaN(parseFloat(v))) {
      totalReal += parseFloat(v); daysWithData++;
    }
  });
  return { totalReal, daysWithData };
}

function getCityReal(cityId) {
  const days = buildDays();
  let total = 0;
  days.forEach(d => { if(d.cityId===cityId && S.reales[d.idx]!==undefined && S.reales[d.idx]!=='') total += parseFloat(S.reales[d.idx])||0; });
  return total;
}

function getCatBudget() {
  const t = getTotals();
  const budget = S.scenarios[S.scenario];
  const emergAmt = budget * S.emergPct / 100;
  return [t.hotel, t.intFlights, t.food, t.entries, emergAmt];
}

function getCatReal() {
  const days = buildDays();
  let hotel=0, transport=0, food=0, entries=0, misc=0;
  days.forEach((d,i) => {
    const r = parseFloat(S.reales[i]) || 0;
    if(r > 0) {
      const b = getCityBudget(d.cityObj);
      const total = b.totalUsd || 1;
      hotel += r * (b.hotel*S.tc/total);
      transport += r * (b.transport/total);
      food += r * (b.food*S.tc/total);
      entries += r * (b.entries/total);
    }
  });
  return [hotel, transport, food, entries, misc];
}

// ===================== ITINERARY DAYS =====================
function buildDays() {
  const days = [];
  const allDays = [
    {cityId:'madrid', cityObj:CITIES[0]},
    {cityId:'paris', cityObj:CITIES[1]},{cityId:'paris', cityObj:CITIES[1]},{cityId:'paris', cityObj:CITIES[1]},
    {cityId:'suiza', cityObj:CITIES[2]},{cityId:'suiza', cityObj:CITIES[2]},{cityId:'suiza', cityObj:CITIES[2]},
    {cityId:'roma', cityObj:CITIES[3]},{cityId:'roma', cityObj:CITIES[3]},{cityId:'roma', cityObj:CITIES[3]},
    {cityId:'florencia', cityObj:CITIES[4]},
    {cityId:'venecia', cityObj:CITIES[5]},
    {cityId:'amsterdam', cityObj:CITIES[6]},{cityId:'amsterdam', cityObj:CITIES[6]},
    {cityId:'praga', cityObj:CITIES[7]},
  ];
  const acts = [
    'Día libre · Ajuste horario · Preparación',
    'Vuelo MAD→CDG · Check-in · Barrio Marais · Cena Seine',
    'Louvre (€17) · Jardin Tuileries · Opera · Champs-Élysées',
    'Torre Eiffel (€26) · Champ de Mars · Montmartre · Sacré-Cœur',
    'TGV París→Lucerna (€60) · Lago Lucerna · Puente de la Capilla',
    'Excursión Interlaken · Vistas Jungfrau · Actividades Alpes',
    'Día en Lucerna · Castillo Gutsch · Mercado central',
    'Vuelo ZRH→FCO (€85) · Trastevere · Fontana di Trevi · Noche romana',
    'Coliseo + Foro Romano (€16) · Palatino · Boca de la Verdad',
    'Vaticano + Capilla Sixtina (€20) · Castillo Sant\'Angelo',
    'Tren Roma→Florencia (€35) · Duomo · Uffizi (€20) · Ponte Vecchio',
    'Tren Florencia→Venecia (€35) · San Marcos · Rialto · Góndola (€80)',
    'Vuelo VCE→AMS (€100) · Canales · Leidseplein · Jordaan',
    'Rijksmuseum (€22) · Casa de Ana Frank (€16) · Bicicleta · Mercado',
    'Vuelo AMS→PRG (€75) · Castillo de Praga · Puente Carlos · ¡Fin tour!',
  ];
  const baseBudgets = [38,210,180,185,195,185,165,215,175,180,200,220,230,185,180];
  const m = SCEN_MULT[S.scenario];
  const start = new Date(2027,2,1);
  allDays.forEach((d,i) => {
    const dt = new Date(start); dt.setDate(dt.getDate()+i);
    days.push({
      idx:i, day:i+1,
      date:dt.toLocaleDateString('es-PE',{day:'2-digit',month:'short'}),
      cityId:d.cityId, cityObj:d.cityObj,
      flag:d.cityObj.flag, city:d.cityObj.name,
      activity:acts[i],
      budget: Math.round(baseBudgets[i]*m),
      real: S.reales[i] !== undefined ? S.reales[i] : ''
    });
  });
  return days;
}

// ===================== SEMÁFORO =====================
function getSemaforo(budgetUsedPct) {
  if(budgetUsedPct <= 85) return {type:'green', label:'EN RANGO', emoji:'●'};
  if(budgetUsedPct <= 100) return {type:'amber', label:'ATENCIÓN', emoji:'●'};
  return {type:'red', label:'EXCEDIDO', emoji:'●'};
}

function renderSemaforo(val, container, big=false) {
  if(!container) return;
  const s = getSemaforo(val);
  const cls = 'sem-'+s.type;
  const sz = big ? 'font-size:16px;padding:6px 14px' : '';
  container.innerHTML = `<span class="semaforo ${cls}" style="${sz}"><span class="sem-dot"></span>${s.label}</span>`;
}

// ===================== CHARTS =====================
function destroyChart(key) {
  if(S.charts[key]) { try{S.charts[key].destroy();}catch(e){} S.charts[key]=null; }
}

function renderDonut() {
  destroyChart('donut');
  const ctx = document.getElementById('chart-donut');
  if(!ctx) return;
  const catBudgets = getCatBudget();
  const total = catBudgets.reduce((a,b)=>a+b,0);
  const legEl = document.getElementById('cat-legend');
  if(legEl) legEl.innerHTML = CATS.map((c,i)=>`<span><span class="leg-dot" style="background:${CAT_COLORS[i]}"></span>${c} ${Math.round(catBudgets[i]/total*100)}%</span>`).join('');
  S.charts.donut = new Chart(ctx, {
    type:'doughnut',
    data:{ labels:CATS, datasets:[{data:catBudgets.map(v=>Math.round(v)), backgroundColor:CAT_COLORS, borderColor:'#f0f2f5', borderWidth:2}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>`${ctx.label}: $${Math.round(ctx.raw).toLocaleString()}`}}},cutout:'60%'}
  });
}

function renderCiudadBar() {
  destroyChart('ciudadbar');
  const ctx = document.getElementById('chart-ciudad-bar');
  if(!ctx) return;
  const labels=CITIES.map(c=>c.flag+' '+c.name.substring(0,3));
  const budgets=CITIES.map(c=>Math.round(getCityBudget(c).totalUsd));
  const reales=CITIES.map(c=>{ const r=getCityReal(c.id); return r>0?Math.round(r):null; });
  S.charts.ciudadbar = new Chart(ctx,{
    type:'bar',
    data:{labels, datasets:[
      {label:'Presup.',data:budgets,backgroundColor:'#1d4ed8',borderColor:'#3b82f6',borderWidth:1},
      {label:'Real',data:reales,backgroundColor:'#0e6e56',borderColor:'#22c55e',borderWidth:1}
    ]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{color:'#6b7280',font:{size:10}}},y:{ticks:{color:'#6b7280',font:{size:10},callback:v=>'$'+v},grid:{color:'#e5e7eb'}}}}
  });
}

function renderCurvaS() {
  destroyChart('curvas');
  const ctx = document.getElementById('chart-curva');
  if(!ctx) return;
  const days = buildDays();
  const labels = days.map(d=>'D'+d.day);
  let cumPlan=0, cumReal=0;
  const planData=[], realData=[];
  days.forEach((d,i)=>{ cumPlan+=d.budget; planData.push(Math.round(cumPlan)); const r=parseFloat(S.reales[i])||0; if(S.reales[i]!==undefined&&S.reales[i]!==''){cumReal+=r;} realData.push(cumReal>0?Math.round(cumReal):null); });
  const legEl=document.getElementById('curva-legend');
  if(legEl) legEl.innerHTML=`<span><span class="leg-dot" style="background:#3b82f6"></span>Presupuesto Acum.</span><span><span class="leg-dot" style="background:#06b6d4"></span>Real Acum.</span>`;
  S.charts.curvas = new Chart(ctx,{
    type:'line',
    data:{labels, datasets:[
      {label:'Presupuesto Acum.',data:planData,borderColor:'#3b82f6',backgroundColor:'rgba(59,130,246,.1)',tension:0.3,borderWidth:2,pointRadius:3,pointBackgroundColor:'#3b82f6'},
      {label:'Real Acum.',data:realData,borderColor:'#06b6d4',backgroundColor:'rgba(6,182,212,.1)',tension:0.3,borderWidth:2,borderDash:[5,3],pointRadius:4,pointBackgroundColor:'#06b6d4',spanGaps:false}
    ]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{color:'#6b7280',font:{size:10}}},y:{ticks:{color:'#6b7280',font:{size:10},callback:v=>'$'+v},grid:{color:'#e5e7eb'}}}}
  });
}

function renderBurnRate() {
  destroyChart('burn');
  const ctx = document.getElementById('chart-burn');
  if(!ctx) return;
  const days=buildDays();
  const labels=days.map(d=>'D'+d.day);
  const planData=days.map(d=>d.budget);
  const realData=days.map((d,i)=>{ const v=S.reales[i]; return (v!==undefined&&v!=='') ? Math.round(parseFloat(v)||0) : null; });
  const legEl=document.getElementById('burn-legend');
  if(legEl) legEl.innerHTML=`<span><span class="leg-dot" style="background:#1d4ed8"></span>Planificado</span><span><span class="leg-dot" style="background:#0e6e56;border:1px dashed #22c55e"></span>Real</span>`;
  S.charts.burn = new Chart(ctx,{
    type:'bar',
    data:{labels, datasets:[
      {label:'Planificado',data:planData,backgroundColor:'rgba(29,78,216,0.7)',borderColor:'#3b82f6',borderWidth:1},
      {label:'Real',data:realData,backgroundColor:'rgba(14,110,86,0.8)',borderColor:'#22c55e',borderWidth:1}
    ]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{color:'#6b7280',font:{size:9}},stacked:false},y:{ticks:{color:'#6b7280',font:{size:10},callback:v=>'$'+v},grid:{color:'#e5e7eb'}}}}
  });
}

function renderProjection() {
  destroyChart('proj');
  const ctx=document.getElementById('chart-proj');
  if(!ctx) return;
  const {totalReal,daysWithData}=getRealTotals();
  const days=buildDays();
  const totPlan=days.reduce((a,d)=>a+d.budget,0);
  const budget=S.scenarios[S.scenario];
  let projFinal=totPlan;
  let conf='N/D';
  if(daysWithData>=3){
    const avgReal=totalReal/daysWithData;
    projFinal=Math.round(avgReal*15);
    const confiabilidad=Math.min(100,Math.round(daysWithData/15*100));
    conf=confiabilidad+'%';
  }
  const diff=budget-projFinal;
  document.getElementById('proj-valor').textContent='$'+projFinal.toLocaleString();
  const pdEl=document.getElementById('proj-diff');
  pdEl.textContent=(diff>=0?'+':'')+('$'+Math.abs(diff).toLocaleString());
  pdEl.style.color=diff>=0?'var(--green)':'var(--red)';
  document.getElementById('proj-conf').textContent=conf;
  S.charts.proj=new Chart(ctx,{
    type:'bar',
    data:{
      labels:['Presupuesto','Proyección'],
