// ===================== EXPORT =====================
function exportExcel() {
  try{
    const days=buildDays();
    const wb=XLSX.utils.book_new();
    const rows=[['EUROPA 2027 · FINANCIAL CONTROLLER'],['Generado:',new Date().toLocaleString('es-PE')],['Escenario:',S.scenario,'Presupuesto:','$'+S.scenarios[S.scenario],'TC EUR/USD:',S.tc],[]];
    rows.push(['DÍA','FECHA','CIUDAD','ACTIVIDAD','PRESUP USD','REAL USD','DIFERENCIA','% DESV.','ACUM PRESUP','ACUM REAL']);
    let cumP=0,cumR=0;
    days.forEach((d,i)=>{
      cumP+=d.budget;
      const r=parseFloat(S.reales[i])||0;
      if(S.reales[i]!==undefined&&S.reales[i]!=='') cumR+=r;
      rows.push([d.day,d.date,d.city,d.activity,d.budget,r||(S.reales[i]!==undefined&&S.reales[i]!==''?r:''),
        S.reales[i]!==undefined&&S.reales[i]!==''?d.budget-r:'',
        S.reales[i]!==undefined&&S.reales[i]!==''?((r-d.budget)/d.budget*100).toFixed(1)+'%':'',
        cumP,cumR||'']);
    });
    rows.push([]);
    rows.push(['CIUDAD','NOCHES','HOTEL USD','COMIDA USD','TRANSP USD','ACT USD','TOTAL USD']);
    CITIES.forEach(c=>{ const b=getCityBudget(c); rows.push([c.name,b.nights,Math.round(b.hotel*S.tc),Math.round(b.food*S.tc),Math.round(b.transport),Math.round(b.entries),Math.round(b.totalUsd)]); });
    const ws=XLSX.utils.aoa_to_sheet(rows);
    XLSX.utils.book_append_sheet(wb,ws,'Dashboard Europa 2027');
    XLSX.writeFile(wb,'EUROPA_2027_Financial_Controller.xlsx');
  }catch(e){alert('Error exportando: '+e.message);}
}

