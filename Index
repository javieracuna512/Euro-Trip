  renderDiarioTable();
  renderDonut();
  renderCiudadBar();
  renderCurvaS();
  renderBurnRate();
  renderProjection();
  renderCatCharts();
  renderCiudadDetail();
  renderCiudadDetailTable();
  renderCatTable();
